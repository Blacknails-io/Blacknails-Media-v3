{
  "name": "blacknails-media-v3-server",
  "version": "3.0.0",
  "description": "Servidor central de Blacknails-Media-v3",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rimraf dist && tsc",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "start": "node dist/index.js",
    "dev": "node --import=tsx --env-file=.env --watch src/index.ts",
    "dev:mock": "node --import=tsx --env-file=.env --watch src/mock-server.ts"
  },
  "dependencies": {
    "@blacknails/shared": "*",
    "better-sqlite3": "^12.11.1",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.2.0",
    "sharp": "^0.35.3",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
