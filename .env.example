# Server
PORT=3000
NODE_ENV=production
COOKIE_SECURE=true
DATABASE_PATH=./data/blacknails.db

# Library paths
IMPORT_DIR=./library/import
ORIGINALS_DIR=./library/originals
ARCHIVE_DIR=./library/archive
THUMBNAILS_DIR=./library/storage/thumbnails
SIDECARS_DIR=./library/storage/sidecars

# Initial users. Change these before first boot.
ADMIN_USER=admin
ADMIN_PASS=change-me-before-first-boot
# Optional viewer seed for sharing/partner access.
PARTNER_USER=
PARTNER_PASS=

# Public registration remains disabled unless explicitly enabled.
ALLOW_PUBLIC_REGISTRATION=false

# Workers. Keep import/index disabled until paths and backups are confirmed.
IMPORT_SCHEDULER_ENABLED=false
INDEX_SCHEDULER_ENABLED=false
IMPORT_INTERVAL_MS=10000
INDEX_INTERVAL_MS=15000
THUMBNAIL_INTERVAL_MS=15000
DESCRIPTION_INTERVAL_MS=30000
TAGS_INTERVAL_MS=30000
TITLE_INTERVAL_MS=30000
NSFW_INTERVAL_MS=30000
FACE_INTERVAL_MS=45000
FACE_CLUSTER_INTERVAL_MS=90000

# AI services
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=blacknails-vision
OLLAMA_TEXT_MODEL=blacknails-text
OLLAMA_VISION_CONCURRENCY=2
OLLAMA_TEXT_CONCURRENCY=2
# Sent per Ollama request. Runtime-level model residency is controlled by the Ollama service.
OLLAMA_KEEP_ALIVE=5m
# Recommended on the Ollama runtime/container, not consumed by this API process:
# OLLAMA_MAX_LOADED_MODELS=2
# OLLAMA_NUM_PARALLEL=2
QDRANT_URL=
NSFW_THRESHOLD=0.6
FACE_PYTHON_BIN=python3
FACE_CLUSTER_THRESHOLD=0.65

# Test-only endpoint switch. Keep false in normal deployments.
ENABLE_TEST_ENDPOINTS=false
